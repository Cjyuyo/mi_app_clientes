-- Se usa CASCADE para borrar las tablas y sus dependencias si existen
DROP TABLE IF EXISTS clientes CASCADE;
DROP TABLE IF EXISTS pagos CASCADE;
DROP SEQUENCE IF EXISTS recibo_numero_seq;

-- Reemplazaré 10612 con el número que tú me indiques.
CREATE SEQUENCE recibo_numero_seq START WITH 10612;

-- La tabla de clientes no cambia en esta actualización
CREATE TABLE clientes (
  id SERIAL PRIMARY KEY,
  cedula TEXT NOT NULL UNIQUE,
  contrato_nro TEXT,
  nombre_apellido TEXT,
  telefono TEXT,
  fecha_ingreso TEXT,
  grupo TEXT,
  bien_solicitado TEXT,
  moneda_pago TEXT,
  asesor TEXT,
  responsable TEXT,
  proceso TEXT,
  estatus TEXT,
  estatus_1 TEXT,
  inscripcion_porcentaje REAL,
  inscripcion_monto REAL,
  valor_cuota REAL,
  fecha_pago_recurrente TEXT,
  estatus_cuota TEXT,
  valor_cancelado REAL,
  observacion TEXT,
  fecha_inscripcion TEXT,
  plan_contratado TEXT,
  reserva_monto_total REAL,
  reserva_monto_pagado REAL,
  cuotas_totales INTEGER,
  cuotas_pagadas_progresivas INTEGER,
  cuotas_pagadas_regresivas INTEGER DEFAULT 0,
  balance_regresivo REAL DEFAULT 0.0,
  pagos_impuntuales INTEGER,
  cuotas_en_mora INTEGER
);

-- Se actualiza la tabla de pagos con los nuevos campos
CREATE TABLE pagos (
  id SERIAL PRIMARY KEY,
  cliente_id INTEGER NOT NULL,
  recibo INTEGER, -- Ahora es opcional al crear, se asigna al conciliar
  monto REAL NOT NULL,
  -- NUEVOS CAMPOS
  monto_usd REAL,
  monto_bs REAL,
  tasa_dia REAL,
  estado TEXT DEFAULT 'Pendiente', -- Por defecto, todos los pagos están pendientes
  cuotas INTEGER NOT NULL,
  forma_pago TEXT NOT NULL,
  fecha_pago TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  pago_en TEXT,
  cantidad_en_letras TEXT,
  por_concepto_de TEXT,
  referencia TEXT,
  banco TEXT,
  lugar_emision TEXT,
  FOREIGN KEY (cliente_id) REFERENCES clientes (id) ON DELETE CASCADE
);
